{
  "name": "liferay-demo-agents",
  "version": "0.2.1",
  "description": "Liferay Demo Builder & Orchestrator with Blade CLI and Liferay Docker Manager (LDM).",
  "migratedTo": "https://github.com/lr-timbraun/liferay-demo-agents",
  "contextFileName": "GEMINI.md",
  "settings": [],
  "mcpServers": {
    "liferay-api-proxy": {
      "command": "node",
      "args": [
        "${extensionPath}${/}index.js"
      ],
      "cwd": "${extensionPath}",
      "env": {
        "WORKSPACE_PATH": "${workspacePath}"
      },
      "timeout": 60000
    }
  }
}